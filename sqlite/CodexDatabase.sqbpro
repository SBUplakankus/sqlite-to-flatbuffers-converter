INSERT INTO resources (id, file_path, resource_type, url, tts_metadata) VALUES
(77020, 'codex/history/the-awakening.png', 2, NULL, NULL),
(127020, 'codex/history/the-awakening.ogg', 1, NULL, '{&quot;voice&quot;:&quot;en_compact_f01&quot;,&quot;speed&quot;:1.0}');

INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(7020, 7, NULL, NULL, 0, 'The Awakening', 'The Awakening is catalogued by the Veil Compact Codex as a core history reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link The Awakening to Great Silence, Awakening, and Founding Wars, with recurring relevance to Sundering across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Syrathi Elders frame the issue as a long-horizon stability problem that demands restraint, archives, and interspecies mediation. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. The Foundry district functions as a pressure valve where legal commerce, grey markets, and intelligence trade overlap. The lesson repeated in every academy is simple: short-term victories fail when they ignore system-level second-order effects.', 127020, 77020, 3);

INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(7021, 7, 7020, NULL, 1, 'The Awakening: Rediscovery of the Gates', 'Rediscovery of the Gates is filed as a secondary codex heading under The Awakening and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Great Silence and Keth''Sa Incident, while historical context from the The Breach clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Keth analysts note the strongest predictive signal comes from logistics, not ideology, because supply lines decide outcomes. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, rediscovery of the gates is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 1),
(7022, 7, 7020, NULL, 1, 'The Awakening: Early Interstellar Contact', 'Early Interstellar Contact is filed as a secondary codex heading under The Awakening and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Great Silence and Keth''Sa Incident, while historical context from the The Breach clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Vaekar doctrine formalised current practice after the Sundering and keeps response windows measured in minutes, not hours. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, early interstellar contact is used as a case study for balancing speed and restraint under uncertain intelligence conditions. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', NULL, NULL, 2),
(7023, 7, 7020, NULL, 1, 'The Awakening: First Conflicts', 'First Conflicts is filed as a secondary codex heading under The Awakening and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Great Silence and Keth''Sa Incident, while historical context from the The Breach clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Durakh clan records preserve contradictory oral histories, but all versions agree that strategic humiliation outlasts military defeat. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, first conflicts is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 3);

