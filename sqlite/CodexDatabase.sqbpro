INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(1020, 1, NULL, NULL, 0, 'Keth', 'Keth is catalogued by the Veil Compact Codex as a core aliens reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Keth to Syrath Prime, Vael, and Keth''Sa, with recurring relevance to Dur''ka across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Syrathi Elders frame the issue as a long-horizon stability problem that demands restraint, archives, and interspecies mediation. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. The Foundry district functions as a pressure valve where legal commerce, grey markets, and intelligence trade overlap. The lesson repeated in every academy is simple: short-term victories fail when they ignore system-level second-order effects.', 61020, 11020, 3);

INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(1021, 1, 1020, NULL, 1, 'Keth: Biology and Physiology', 'Biology and Physiology is filed as a secondary codex heading under Keth and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Keth analysts note the strongest predictive signal comes from logistics, not ideology, because supply lines decide outcomes. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, biology and physiology is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 1),
(1022, 1, 1020, NULL, 1, 'Keth: The Data Union and House System', 'The Data Union and House System is filed as a secondary codex heading under Keth and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Vaekar doctrine formalised current practice after the Sundering and keeps response windows measured in minutes, not hours. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, the data union and house system is used as a case study for balancing speed and restraint under uncertain intelligence conditions. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', NULL, NULL, 2),
(1023, 1, 1020, NULL, 1, 'Keth: Intelligence Culture', 'Intelligence Culture is filed as a secondary codex heading under Keth and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Durakh clan records preserve contradictory oral histories, but all versions agree that strategic humiliation outlasts military defeat. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, intelligence culture is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 3),
(1024, 1, 1020, NULL, 1, 'Keth: Lifespan and the Culture of Urgency', 'Lifespan and the Culture of Urgency is filed as a secondary codex heading under Keth and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. The Foundry district functions as a pressure valve where legal commerce, grey markets, and intelligence trade overlap. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, lifespan and the culture of urgency is used as a case study for balancing speed and restraint under uncertain intelligence conditions. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', NULL, NULL, 4);

