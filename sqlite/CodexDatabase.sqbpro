VALUES
(1010, 1, NULL, NULL, 0, 'Vaekar', 'Vaekar is catalogued by the Veil Compact Codex as a core aliens reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Vaekar to Syrath Prime, Vael, and Keth''Sa, with recurring relevance to Dur''ka across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Reclamation teams continue to cross-reference Architect-era fragments with modern telemetry to close persistent evidentiary gaps. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Gate-adjacent populations report measurable psychological effects during sustained alert periods, especially among transit crews. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', 61010, 11010, 2);

INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(1011, 1, 1010, NULL, 1, 'Vaekar: Biology and Physiology', 'Biology and Physiology is filed as a secondary codex heading under Vaekar and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Reclamation teams continue to cross-reference Architect-era fragments with modern telemetry to close persistent evidentiary gaps. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, biology and physiology is used as a case study for balancing speed and restraint under uncertain intelligence conditions. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', NULL, NULL, 1),
(1012, 1, 1010, NULL, 1, 'Vaekar: The Hierarchy System', 'The Hierarchy System is filed as a secondary codex heading under Vaekar and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Public education editions remove casualty imagery, yet service editions retain full after-action appendices for training. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, the hierarchy system is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 2),
(1013, 1, 1010, NULL, 1, 'Vaekar: Facial Markings and Colony Culture', 'Facial Markings and Colony Culture is filed as a secondary codex heading under Vaekar and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Independent Arbiter assessments routinely classify local governance quality as the deciding factor in long-term recovery. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, facial markings and colony culture is used as a case study for balancing speed and restraint under uncertain intelligence conditions. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', NULL, NULL, 3),
(1014, 1, 1010, NULL, 1, 'Vaekar: Dextro-Amino Physiology', 'Dextro-Amino Physiology is filed as a secondary codex heading under Vaekar and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Accord medical directorates maintain shared registries to track delayed exposure outcomes tied to Null-Matter contamination. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, dextro-amino physiology is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 4),
(1015, 1, 1010, NULL, 1, 'Vaekar: Vaekar and the Wasting Curse', 'Vaekar and the Wasting Curse is filed as a secondary codex heading under Vaekar and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. The Accord Council treats the subject as strategically sensitive and updates advisories quarterly from the Spire. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, vaekar and the wasting curse is used as a case study for balancing speed and restraint under uncertain intelligence conditions. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', NULL, NULL, 5);

