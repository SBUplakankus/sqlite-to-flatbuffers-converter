INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(4000, 4, NULL, NULL, 0, 'Void Gate Combat', 'Void Gate Combat is catalogued by the Veil Compact Codex as a core military reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Void Gate Combat to Void Gates, Null Lancers, and Hierarchy battle groups, with recurring relevance to barrier doctrine across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Independent Arbiter assessments routinely classify local governance quality as the deciding factor in long-term recovery. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Field records from 2712 PF onward show local variation driven by gate traffic density, climate load, and military pressure. This is why Accord briefings separate tactical confidence from strategic confidence and prohibit collapsing the two metrics.', 94000, 44000, 1);

