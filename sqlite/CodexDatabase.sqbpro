INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(1040, 1, NULL, NULL, 0, 'Nomari', 'Nomari is catalogued by the Veil Compact Codex as a core aliens reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Nomari to Syrath Prime, Vael, and Keth''Sa, with recurring relevance to Dur''ka across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Cross-species standards now require explicit compatibility notes for dextro and levo biochemistry in all deployed systems. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. The Accord Council treats the subject as strategically sensitive and updates advisories quarterly from the Spire. This is why Accord briefings separate tactical confidence from strategic confidence and prohibit collapsing the two metrics.', 61040, 11040, 5);

