in" name="requirements" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="32"/><column index="2" value="330"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="resources" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="54"/><column index="2" value="300"/><column index="3" value="111"/><column index="4" value="39"/><column index="5" value="300"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- ============================================================
-- Veil Compact Codex Database - Full SQL Export (Generated)
-- Mass Effect 2 codex-adjacent structure and tone (original IP)
-- ============================================================

PRAGMA foreign_keys = OFF;

-- Schema
CREATE TABLE &quot;categories&quot; (
    &quot;id&quot;         INTEGER PRIMARY KEY,
    &quot;name&quot;       TEXT NOT NULL,
    &quot;sort_order&quot; INTEGER DEFAULT 0
);

CREATE TABLE &quot;requirements&quot; (
    &quot;id&quot;          INTEGER PRIMARY KEY,
    &quot;description&quot; TEXT NOT NULL
);

CREATE TABLE &quot;resources&quot; (
    &quot;id&quot;            INTEGER PRIMARY KEY,
    &quot;file_path&quot;     TEXT NOT NULL,
    &quot;resource_type&quot; INTEGER,
    &quot;url&quot;           TEXT,
    &quot;tts_metadata&quot;  TEXT
);

CREATE TABLE &quot;codex_entries&quot; (
    &quot;id&quot;              INTEGER PRIMARY KEY,
    &quot;category_id&quot;     INTEGER NOT NULL,
    &quot;parent_entry_id&quot; INTEGER,
    &quot;requirement_id&quot;  INTEGER,
    &quot;entry_type&quot;      INTEGER NOT NULL,
    &quot;title&quot;           TEXT NOT NULL,
    &quot;content&quot;         TEXT NOT NULL,
    &quot;audio_id&quot;        INTEGER,
    &quot;image_id&quot;        INTEGER,
    &quot;sort_order&quot;      INTEGER DEFAULT 0,
    FOREIGN KEY(&quot;category_id&quot;)     REFERENCES &quot;categories&quot;(&quot;id&quot;),
    FOREIGN KEY(&quot;parent_entry_id&quot;) REFERENCES &quot;codex_entries&quot;(&quot;id&quot;),
    FOREIGN KEY(&quot;requirement_id&quot;)  REFERENCES &quot;requirements&quot;(&quot;id&quot;),
    FOREIGN KEY(&quot;audio_id&quot;)        REFERENCES &quot;resources&quot;(&quot;id&quot;),
    FOREIGN KEY(&quot;image_id&quot;)        REFERENCES &quot;resources&quot;(&quot;id&quot;)
);

CREATE INDEX IF NOT EXISTS idx_entries_category ON codex_entries(category_id);
CREATE INDEX IF NOT EXISTS idx_entries_parent   ON codex_entries(parent_entry_id);
CREATE INDEX IF NOT EXISTS idx_entries_type     ON codex_entries(entry_type);

-- Categories
INSERT INTO categories (id, name, sort_order) VALUES
(1, 'Aliens', 1),
(2, 'Humanity', 2),
(3, 'Government', 3),
(4, 'Military', 4),
(5, 'Technology', 5),
(6, 'Worlds', 6),
(7, 'History', 7),
(8, 'Culture', 8),
(9, 'Economy', 9),
(10, 'The Hollow', 10);

-- Requirements
INSERT INTO requirements (id, description) VALUES
(1, 'Complete the first Hollow encounter'),
(2, 'Complete Act 1'),
(3, 'Complete Act 2'),
(4, 'Join the Reclamation');

-- ============================================================
-- Category: Aliens  |  Primary: Syrathi
-- ============================================================

INSERT INTO resources (id, file_path, resource_type, url, tts_metadata) VALUES
(11000, 'codex/aliens/syrathi.png', 2, NULL, NULL),
(61000, 'codex/aliens/syrathi.ogg', 1, NULL, '{&quot;voice&quot;:&quot;en_compact_f01&quot;,&quot;speed&quot;:1.0}');

INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(1000, 1, NULL, NULL, 0, 'Syrathi', 'Syrathi is catalogued by the Veil Compact Codex as a core aliens reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Syrathi to Syrath Prime, Vael, and Keth''Sa, with recurring relevance to Dur''ka across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Independent Arbiter assessments routinely classify local governance quality as the deciding factor in long-term recovery. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Field records from 2712 PF onward show local variation driven by gate traffic density, climate load, and military pressure. This is why Accord briefings separate tactical confidence from strategic confidence and prohibit collapsing the two metrics.', 61000, 11000, 1);

INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(1001, 1, 1000, NULL, 1, 'Syrathi: Biology and Physiology', 'Biology and Physiology is filed as a secondary codex heading under Syrathi and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Gate-adjacent populations report measurable psychological effects during sustained alert periods, especially among transit crews. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, biology and physiology is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 1),
(1002, 1, 1000, NULL, 1, 'Syrathi: Society and the Matriarchy', 'Society and the Matriarchy is filed as a secondary codex heading under Syrathi and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Compact economists treat the category as a macro-stability indicator because disruptions propagate through credit and insurance rates. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, society and the matriarchy is used as a case study for balancing speed and restraint under uncertain intelligence conditions. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', NULL, NULL, 2),
(1003, 1, 1000, NULL, 1, 'Syrathi: Resonance and Culture', 'Resonance and Culture is filed as a secondary codex heading under Syrathi and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Field records from 2712 PF onward show local variation driven by gate traffic density, climate load, and military pressure. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, resonance and culture is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 3),
(1004, 1, 1000, NULL, 1, 'Syrathi: The Three Life Phases', 'The Three Life Phases is filed as a secondary codex heading under Syrathi and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Syrathi Elders frame the issue as a long-horizon stability problem that demands restraint, archives, and interspecies mediation. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, the three life phases is used as a case study for balancing speed and restraint under uncertain intelligence conditions. Planners therefore rank the domain as high consequence even when incident frequency appears low in public summaries.', NULL, NULL, 4),
(1005, 1, 1000, NULL, 1, 'Syrathi: Neural-Bond Reproduction', 'Neural-Bond Reproduction is filed as a secondary codex heading under Syrathi and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Syrath Prime and Nom''ara, while historical context from the Wandering Armada clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Nomari engineering briefs emphasise redundancy and isolation because single-point failure remains the dominant operational risk. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, neural-bond reproduction is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 5);

