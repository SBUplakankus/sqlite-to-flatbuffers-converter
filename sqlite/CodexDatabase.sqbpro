INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(3000, 3, NULL, NULL, 0, 'The Spire', 'The Spire is catalogued by the Veil Compact Codex as a core government reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link The Spire to The Spire, Accord Council, and Arbiters, with recurring relevance to Accord Law across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Field records from 2712 PF onward show local variation driven by gate traffic density, climate load, and military pressure. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Durakh clan records preserve contradictory oral histories, but all versions agree that strategic humiliation outlasts military defeat. This is why Accord briefings separate tactical confidence from strategic confidence and prohibit collapsing the two metrics.', 83000, 33000, 1);

