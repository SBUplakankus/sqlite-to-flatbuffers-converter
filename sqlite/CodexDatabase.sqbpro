INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(7080, 7, NULL, 2, 0, 'The Breach', 'The Breach is catalogued by the Veil Compact Codex as a core history reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link The Breach to Great Silence, Awakening, and Founding Wars, with recurring relevance to Sundering across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Public education editions remove casualty imagery, yet service editions retain full after-action appendices for training. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Compact economists treat the category as a macro-stability indicator because disruptions propagate through credit and insurance rates. This is why Accord briefings separate tactical confidence from strategic confidence and prohibit collapsing the two metrics.', 127080, 77080, 9);

