INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(9030, 9, NULL, NULL, 0, 'Trade Routes', 'Trade Routes is catalogued by the Veil Compact Codex as a core economy reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Trade Routes to Accord Credit, Oshari banking houses, and Aethite futures, with recurring relevance to trade chokepoints across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Vaekar doctrine formalised current practice after the Sundering and keeps response windows measured in minutes, not hours. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Public education editions remove casualty imagery, yet service editions retain full after-action appendices for training. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', 149030, 99030, 4);

