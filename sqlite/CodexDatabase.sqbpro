INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(6020, 6, NULL, NULL, 0, 'Vael', 'Vael is catalogued by the Veil Compact Codex as a core worlds reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Vael to Auris System, Veil Expanse, and Null Rift, with recurring relevance to orbital infrastructure across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. The Foundry district functions as a pressure valve where legal commerce, grey markets, and intelligence trade overlap. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Accord medical directorates maintain shared registries to track delayed exposure outcomes tied to Null-Matter contamination. The lesson repeated in every academy is simple: short-term victories fail when they ignore system-level second-order effects.', 116020, 66020, 3);

