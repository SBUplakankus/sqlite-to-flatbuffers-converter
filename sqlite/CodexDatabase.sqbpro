INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(6000, 6, NULL, NULL, 0, 'Terra', 'Terra is catalogued by the Veil Compact Codex as a core worlds reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Terra to Auris System, Veil Expanse, and Null Rift, with recurring relevance to orbital infrastructure across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Field records from 2712 PF onward show local variation driven by gate traffic density, climate load, and military pressure. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Durakh clan records preserve contradictory oral histories, but all versions agree that strategic humiliation outlasts military defeat. This is why Accord briefings separate tactical confidence from strategic confidence and prohibit collapsing the two metrics.', 116000, 66000, 1);

INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(6001, 6, 6000, NULL, 1, 'Terra: Sol System', 'Sol System is filed as a secondary codex heading under Terra and serves as a practical briefing layer for commanders, diplomats, and investigators. The current synthesis ties the topic to Auris System and frontier colonies, while historical context from the survey expeditions clarifies why policy language remains deliberately conservative. Analysts emphasize that this subtopic cannot be read apart from infrastructure strain, legal jurisdiction boundaries, and the uneven administrative capacity of member worlds. Keth analysts note the strongest predictive signal comes from logistics, not ideology, because supply lines decide outcomes. Recent audits found that outcomes improve when local actors share telemetry early, standardize terminology, and publish cross-species compatibility guidance before incidents escalate. In training doctrine, sol system is used as a case study for balancing speed and restraint under uncertain intelligence conditions. As a result, most command schools teach conservative escalation ladders with mandatory civilian-harm checkpoints.', NULL, NULL, 1),
