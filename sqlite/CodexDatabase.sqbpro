INSERT INTO codex_entries
    (id, category_id, parent_entry_id, requirement_id, entry_type, title, content, audio_id, image_id, sort_order)
VALUES
(2000, 2, NULL, NULL, 0, 'Terran Hegemony', 'Terran Hegemony is catalogued by the Veil Compact Codex as a core humanity reference topic and is maintained by analysts on the Spire for active policy use. Current briefs link Terran Hegemony to Terran Hegemony, Council of Ministers, and Hegemony Fleet Command, with recurring relevance to HID across both frontier and core systems. In post-Breach doctrine, the subject is no longer treated as static background lore but as an operational variable that shapes Accord readiness, diplomatic posture, and civilian confidence. Durakh clan records preserve contradictory oral histories, but all versions agree that strategic humiliation outlasts military defeat. Comparative reviews from 2698 PF to 2740 PF show that decision quality improves when planners evaluate technical limits, legal mandates, and cultural memory together rather than in isolation. Records from Arbiter debriefs and Directorate archives repeatedly highlight spillover effects into trade, migration, and recruitment pipelines whenever this domain is mishandled. Independent Arbiter assessments routinely classify local governance quality as the deciding factor in long-term recovery. This is why Accord briefings separate tactical confidence from strategic confidence and prohibit collapsing the two metrics.', 72000, 22000, 1);

